/* css styles */
/* Navbar */
.navbar {
  background-color: white !important;
  border-bottom: 1px solid #e0e0e0;
}

.navbar-brand {
  font-weight: bold;
  color: #333 !important;
}

.nav-link {
  color: #333 !important;
}

.nav-link.active {
  color: #4a90d9 !important;
  font-weight: 600;
}

/* Body */
body {
  font-family: 'Georgia', serif;
  color: #333;
  background-color: white;
}

/* Headings */
h1, h2, h3 {
  font-weight: bold;
  color: #222;
}